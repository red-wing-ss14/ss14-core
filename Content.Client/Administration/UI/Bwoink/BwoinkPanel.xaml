<BoxContainer
    xmlns="https://spacestation14.io"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:rw="clr-namespace:Content.Client._RW.UserInterface.Systems.Chat.Controls"
    Orientation="Vertical"
    HorizontalExpand="True">
    <OutputPanel Name="TextOutput" VerticalExpand="true" />
    <RichTextLabel Name="TypingIndicator" Access="Public" />
    <!-- RW start -->
    <BoxContainer Orientation="Horizontal" HorizontalExpand="True" SeparationOverride="4">
        <HistoryLineEdit Name="SenderLineEdit" HorizontalExpand="True"/>
        <rw:EmojiPickerButton Name="EmojiBtn" />
    </BoxContainer>
    <!-- RW end -->
    <RichTextLabel Name="RelayedToDiscordLabel" Access="Public" Visible="False" />
</BoxContainer>

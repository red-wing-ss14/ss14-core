<controls:EmojiPickerPopup
    xmlns="https://spacestation14.io"
    xmlns:controls="clr-namespace:Content.Client._RW.UserInterface.Systems.Chat.Controls"
    MinSize="600 440">
    <PanelContainer Name="EmojiPopupPanel" StyleClasses="BorderedWindowPanel" MinSize="600 440">
        <BoxContainer
            Orientation="Horizontal"
            SeparationOverride="8"
            Margin="8"
            HorizontalExpand="True"
            VerticalExpand="True">
            <PanelContainer MinWidth="42" StyleClasses="Inset">
                <BoxContainer
                    Name="CategoryBox"
                    Orientation="Vertical"
                    SeparationOverride="4"
                    Margin="4" />
            </PanelContainer>
            <BoxContainer
                Orientation="Vertical"
                SeparationOverride="6"
                HorizontalExpand="True"
                VerticalExpand="True">
                <BoxContainer Orientation="Horizontal" HorizontalExpand="True">
                    <Label
                        Name="HeaderLabel"
                        Margin="4 0"
                        HorizontalExpand="True"
                        StyleClasses="LabelHeading" />
                    <TextureButton
                        Name="CloseButton"
                        StyleClasses="windowCloseButton"
                        VerticalAlignment="Center" />
                </BoxContainer>
                <ScrollContainer
                    HorizontalExpand="True"
                    VerticalExpand="True"
                    HScrollEnabled="False"
                    ReserveScrollbarSpace="True">
                    <PanelContainer HorizontalExpand="True" StyleClasses="Inset">
                        <GridContainer
                            Name="EmojiGrid"
                            Columns="9"
                            HSeparationOverride="6"
                            VSeparationOverride="8"
                            Margin="8 8 8 8" />
                    </PanelContainer>
                </ScrollContainer>
                <RichTextLabel
                    Name="PreviewLabel"
                    Margin="4 0"
                    ModulateSelfOverride="#E6DEC7" />
            </BoxContainer>
        </BoxContainer>
    </PanelContainer>
</controls:EmojiPickerPopup>


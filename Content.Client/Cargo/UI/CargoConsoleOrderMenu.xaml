<!-- basically all of this has been changed by goobstation to a new UI, See PR #4780-->
<DefaultWindow xmlns="https://spacestation14.io"
               Title="{Loc 'cargo-console-order-menu-title'}"
               MinSize="460 261">
    <BoxContainer Orientation="Vertical">
        <GridContainer Columns="2">
            <Label Text="{Loc 'cargo-console-order-menu-product-label'}"
                   StyleClasses="LabelKeyText" />

            <Label Name="ProductName"
                   Access="Public" />

            <Label Text="{Loc 'cargo-console-order-menu-description-label'}"
                   StyleClasses="LabelKeyText" />

            <RichTextLabel Name="Description"
                           Access="Public"
                           HorizontalExpand="True"
                           MaxWidth="460" />

            <Label Text="{Loc 'cargo-console-order-menu-cost-label'}"
                   StyleClasses="LabelKeyText" />

            <Label Name="PointCost"
                   Access="Public" />

            <Label Text="{Loc 'cargo-console-order-menu-requester-label'}"
                   StyleClasses="LabelKeyText" />

            <!-- Orion-Edit -->
            <LineEdit Name="Requester"
                      Access="Public" Editable="False"/>

            <!-- Orion-Edit -->
            <Label Text="{Loc 'cargo-console-order-menu-delivery-destination'}"
                   StyleClasses="LabelKeyText" />

            <!-- Orion-Start -->
            <LineEdit Name="DeliveryDestination"
                      Access="Public" PlaceHolder="{Loc 'cargo-console-paper-delivery-destination-default'}"/>

            <Label Text="{Loc 'cargo-console-order-menu-note'}"
                StyleClasses="LabelKeyText" />

            <LineEdit Name="Note"
                      Access="Public" PlaceHolder="{Loc 'cargo-console-paper-note-default'}"/>
            <!-- Orion-End -->

            <Label Text="{Loc 'cargo-console-order-menu-amount-label'}"
                   StyleClasses="LabelKeyText" />

            <SpinBox Name="Amount"
                     Access="Public"
                     HorizontalExpand="True"
                     Value="1" />

            <!-- Orion-Start -->
            <CheckBox Name="ToggleDepartmentSecureCrate" Access="Public" Text="{Loc 'cargo-console-secure-order-checkbox'}" />
            <CheckBox Name="TogglePrivatePurchase" Access="Public" Text="{Loc 'cargo-console-order-private-checkbox'}" ToolTip="{Loc 'cargo-console-order-private-tooltip'}" />
            <!-- Orion-End -->

        </GridContainer>
        <Control VerticalExpand="True"/>
        <PanelContainer StyleClasses="LowDivider" Margin="0 6 0 2"/>
        <Button Name="SubmitButton"
                Access="Public"
                Text="{Loc 'cargo-console-order-menu-submit-button'}"
                VerticalAlignment="Bottom" />
    </BoxContainer>
</DefaultWindow>

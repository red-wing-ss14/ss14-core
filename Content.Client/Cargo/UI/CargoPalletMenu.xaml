<!-- Orion-Edit-Start -->
<controls:FancyWindow xmlns="https://spacestation14.io"
                      xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
                      Title="{Loc 'cargo-pallet-console-menu-title'}"
                      SetSize="620 620"
                      MinSize="620 620">
    <TabContainer Name="TabContainer" VerticalExpand="True">
        <BoxContainer Orientation="Vertical" Margin="8" SeparationOverride="8">
            <BoxContainer Orientation="Horizontal">
                <Label Text="{Loc 'cargo-pallet-menu-appraisal-label'}" StyleClasses="LabelKeyText" />
                <Label Name="AppraisalLabel" Text="{Loc 'cargo-pallet-menu-no-goods-text'}" />
            </BoxContainer>
            <BoxContainer Orientation="Horizontal">
                <Label Text="{Loc 'cargo-pallet-menu-count-label'}" StyleClasses="LabelKeyText" />
                <Label Name="CountLabel" Text="{Loc 'cargo-pallet-menu-no-goods-text'}" />
            </BoxContainer>
            <Button Name="AppraiseButton" Text="{Loc 'cargo-pallet-appraise-button'}"/>
            <Button Name="SellButton" Text="{Loc 'cargo-pallet-sell-button'}"/>
            <TextureButton VerticalExpand="True" />
        </BoxContainer>

        <BoxContainer Orientation="Vertical" Margin="8" SeparationOverride="6" VerticalExpand="True">
            <controls:StripeBack><Label Text="{Loc 'cargo-pallet-market-increased-demand'}" Margin="4"/></controls:StripeBack>
            <ScrollContainer MinHeight="80" VerticalExpand="True"><BoxContainer Name="IncreasedContainer" Orientation="Vertical" SeparationOverride="2"/></ScrollContainer>
            <controls:StripeBack><Label Text="{Loc 'cargo-pallet-market-decreased-demand'}" Margin="4"/></controls:StripeBack>
            <ScrollContainer MinHeight="80" VerticalExpand="True"><BoxContainer Name="DecreasedContainer" Orientation="Vertical" SeparationOverride="2"/></ScrollContainer>
            <controls:StripeBack><Label Text="{Loc 'cargo-pallet-market-recent-changes'}" Margin="4"/></controls:StripeBack>
            <ScrollContainer MinHeight="100" VerticalExpand="True"><BoxContainer Name="RecentContainer" Orientation="Vertical" SeparationOverride="2"/></ScrollContainer>
            <Label Name="NoChangesLabel" Text="{Loc 'cargo-pallet-market-no-active-changes'}" HorizontalAlignment="Center" Visible="False"/>
        </BoxContainer>
    </TabContainer>
</controls:FancyWindow>
<!-- Orion-Edit-End -->

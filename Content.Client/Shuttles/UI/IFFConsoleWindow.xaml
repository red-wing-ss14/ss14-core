<controls:FancyWindow xmlns="https://spacestation14.io"
                           xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
                           Title="{Loc 'iff-console-window-title'}"
                           MinSize="250 100">
    <BoxContainer Orientation="Vertical" HorizontalExpand="True" Margin="10">
        <controls:SwitchButton Name="ShowIFFSwitch"
                               Text="{Loc 'iff-console-show-iff-label'}"
                               OnStateText="{Loc 'iff-console-on'}"
                               OffStateText="{Loc 'iff-console-off'}"
                               StyleClasses="highlight"/>
    </BoxContainer>
</controls:FancyWindow>
